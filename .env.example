# Production server bind (use 0.0.0.0 so coworkers on LAN/VPN can reach the app).
APP_HOST=0.0.0.0
APP_PORT=5000
APP_THREADS=4

AUTODESK_CLIENT_ID=
AUTODESK_CLIENT_SECRET=
AUTODESK_DEV_ACCOUNT_ID=945eee86-c752-4cca-8f96-3ae4e2914de6
AUTODESK_PROD_ACCOUNT_ID=7a76e43e-8a68-46c3-a7d7-aa1cf331f936
AUTODESK_IMPERSONATION_USER_ID=
AUTODESK_BASE_URL=https://developer.api.autodesk.com
ACC_ENVIRONMENT=dev

# Stratus admin sessions — IT ONLY (copy full Cookie header from DevTools).
STRATUS_DEV_SESSION_COOKIE=
STRATUS_PROD_SESSION_COOKIE=
# Legacy fallback if dev/prod cookies are not set separately:
STRATUS_SESSION_COOKIE=

# Group on disable (dev=Custom, prod=Former Employee).
STRATUS_DEV_FORMER_EMPLOYEE_GROUP=Custom
STRATUS_PROD_FORMER_EMPLOYEE_GROUP=(Former Employee)
STRATUS_FORMER_EMPLOYEE_GROUP=(Former Employee)

# defaultProjectRoleId on disable — empty clears role to None.
STRATUS_DEV_DISABLE_DEFAULT_PROJECT_ROLE_ID=
STRATUS_PROD_DISABLE_DEFAULT_PROJECT_ROLE_ID=

STRATUS_DEV_TEST_PK=
STRATUS_PROD_TEST_PK=
STRATUS_TEST_PK=

# Revizto API (virginia region for UMCI — change REVIZTO_BASE_URL if needed).
REVIZTO_BASE_URL=https://api.virginia.revizto.com
# One-time code from Workspace -> My Account -> Active Sessions -> API (15 min).
REVIZTO_ACCESS_CODE=
REVIZTO_ACCESS_TOKEN=
REVIZTO_REFRESH_TOKEN=
# Legacy alias still supported by the app:
REVIZTO_REFRESH_CODE=
REVIZTO_ACCESS_TOKEN_EXPIRES_AT=
# Optional — only if Revizto issued your app with these:
REVIZTO_CLIENT_ID=
REVIZTO_REDIRECT_URI=
# Numeric license id for activate/deactivate (defaults to your first license).
REVIZTO_LICENSE_ID=34779
# Copied from a Revizto client request, or leave blank to auto-generate once.
REVIZTO_DEVICE_ID=
# Full Cookie header from ws.revizto.com (required for activate/deactivate).
REVIZTO_SESSION_COOKIE=

# Sandbox roster view: https://umci.trackvia.com/#/apps/2/tables/22/views/993?accountId=802489
TRACKVIA_BASE_URL=https://umci.trackvia.com
TRACKVIA_VIEW_ID=993
TRACKVIA_ACCOUNT_ID=802489
# Optional — Open API host (defaults to go.trackvia.com when ACCOUNT_ID is set).
TRACKVIA_OPENAPI_BASE_URL=
TRACKVIA_API_KEY=
TRACKVIA_ACCESS_TOKEN=
TRACKVIA_EMAIL_FIELD=Email From Viewpoint
TRACKVIA_STATUS_FIELD=TrackVia Usage
TRACKVIA_STATUS_ACTIVE=Existing TrackVia User
TRACKVIA_STATUS_DISABLED=Deactivated TrackVia User
TRACKVIA_DISABLE_ACTION=Deactivate Now

# IT-only: secret for pushing session cookies via connect_sessions.py or browser extension.
SESSION_ADMIN_KEY=
# Optional default when connect_sessions.py pushes to a remote server:
SESSION_CONNECT_SERVER=

# OpenSpace org admin session (Team Management — remove from organization).
OPENSPACE_BASE_URL=https://openspace.ai
OPENSPACE_ORG_ID=
# Full Cookie header from openspace.ai after signing in as Org Admin.
OPENSPACE_SESSION_COOKIE=
# Legacy alias:
OPENSPACE_COOKIE=
# Optional Usage API key for membership lookup fallback (api.us.openspace.ai).
OPENSPACE_API_KEY=
OPENSPACE_EXTERNAL_API_BASE_URL=https://api.us.openspace.ai
# Override internal routes if OpenSpace changes their web API.
OPENSPACE_DELETE_USERS_PATH=/api/v3/users/delete
# Default member list: GET /api/v3/users?orgId=...
OPENSPACE_MEMBERS_LIST_PATH=/api/v3/users
OPENSPACE_MEMBERS_SEARCH_PATH=

# Symetri My Symetri license admin API (remove user from company account).
SYMETRI_API_BASE_URL=https://backend.my.symetri.com
SYMETRI_WEB_ORIGIN=https://my.symetri.com
SYMETRI_ACCOUNT_ID=
# Bearer token from Authorization header after signing in at my.symetri.com (expires; refresh from DevTools).
SYMETRI_BEARER_TOKEN=
# Optional overrides:
# SYMETRI_USERS_LIST_PATH=/v1/AccountUsers/{account_id}
# SYMETRI_DELETE_USER_PATH=/v1/AccountUsers/{account_id}/{user_id}

# PlanGrid Admin Console session (preferred — same route as DevTools Users page).
# Org id is in the URL: /enterprise/organizations/<ORG_ID>/users
PLANGRID_APP_BASE_URL=https://app.plangrid.com
PLANGRID_ORG_ID=
# Full Cookie header from the /proxy/aapi2/organizations/.../users request.
PLANGRID_SESSION_COOKIE=
# Optional override (default matches Admin Console DELETE remove):
# PLANGRID_ORG_REMOVE_PATH=/proxy/aapi1/organization/{org_id}/users
# Optional legacy public API (only if Autodesk issued you a key):
# PLANGRID_BASE_URL=https://io.plangrid.com
# PLANGRID_API_KEY=
